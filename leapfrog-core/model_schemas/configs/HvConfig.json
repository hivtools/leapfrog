      "num_type": "real_type"
    },
    "adults": {
      "num_type": "real_type",
      "dims": ["SS::pBothSexes", "SS::pRG_TOTAL", "SS::pHIV", "SS::pVacc", "opts.proj_steps"]
    }
  },

  "state": {
    "ex_output": {
      "num_type": "real_type"
    },
    "b_condom_prop_sum": {
      "num_type": "real_type"
    }
