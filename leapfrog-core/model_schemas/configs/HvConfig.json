{
  "name": "Hv",
  "long_name": "Goals",
  "namespace": "hv",
  "enable_if": "run_goals",
  "state_space": {
    "default": {
      "pBothSexes": 2,
      "pRG_TOTAL": 11,
      "pRG_MSM_F3": 17,
      "pDUR_AVG": 3,
      "pHIV": 19,
      "pVacc": 4
    }
  },
  "pars": {
    "epi_initial_pulse": {
      "num_type": "real_type"
    },
      
    "b_condom_prop": {
      "num_type": "real_type",
      "dims": ["SS::pRG_TOTAL", "opts.proj_steps"]
    },

    "b_behav": {
      "num_type": "real_type",
      "dims": ["SS::pRG_MSM_F3", "SS::pDUR_AVG"]
    },

   "b_sex_acts": {
      "num_type": "real_type",
      "dims": ["SS::pRG_MSM_F3", "opts.proj_steps"]
    },

    "b_num_partners": {
      "num_type": "real_type",
      "dims": ["SS::pRG_MSM_F3", "opts.proj_steps"]
    }
  },

  "intermediate": {
